<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.Fragments.TeacherSide.StudentFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:id="@+id/heading"
        android:weightSum="6"
        android:background="@mipmap/internal_header">
        <ImageButton
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"
            android:layout_marginLeft="5dp"
            android:id="@+id/backBtn"
            android:background="@android:color/transparent"
            android:src="@mipmap/back_arrow"
            android:layout_gravity="center"
            android:layout_marginTop="-10dp"
            android:translationZ="10dp"
            />

        <TextView
            android:layout_width="0dp"
            android:layout_weight="4"
            android:layout_height="wrap_content"
            android:text="Students"
            android:textColor="@color/white"
            android:textSize="18sp"

            android:textAlignment="center"
            android:gravity="center"
            android:layout_marginTop="-10dp"
            android:layout_gravity="center"
            android:fontFamily="@font/rubik_bold" />

        <ImageButton
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="50dp"
            android:layout_marginLeft="5dp"
            android:id="@+id/search"
            android:background="@android:color/transparent"
            android:src="@mipmap/search"
            android:layout_gravity="center"
            android:layout_marginTop="-10dp"
            android:translationZ="50dp"
            />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/heading">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">



                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="5dp"
                    android:visibility="gone"
                    android:id="@+id/searchLayout"
                    android:layout_margin="5dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="5dp">

                        <EditText
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:layout_marginHorizontal="10dp"
                            android:inputType="textPassword"
                            android:id="@+id/studentName"
                            android:textAlignment="center"
                            android:layout_marginTop="25dp"
                            android:textColorHint="@color/appThemeOpacity"
                            android:textColor="@color/appThemeColor"
                            android:background="@drawable/edittext_bg"
                            android:hint="Student Name" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:weightSum="2"
                            android:id="@+id/studentClassSecLayout"
                            android:layout_marginTop="10dp"
                            android:layout_below="@+id/studentName"
                            android:orientation="horizontal">
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:id="@+id/classNameSelect"
                                android:layout_margin="5dp"
                                android:weightSum="3"
                                android:background="@drawable/edittext_bg"
                                android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_weight="2.5"
                                        android:layout_height="45dp"
                                        android:layout_gravity="center"
                                        android:padding="10dp"
                                        android:fontFamily="@font/rubik_regular"
                                        android:textSize="15sp"
                                        android:layout_centerVertical="true"
                                        android:gravity="center"
                                        android:id="@+id/selectClass"
                                        android:text="Class"
                                        android:textColor="@color/appThemeColor"/>



                                <ImageView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="0.5"
                                    android:src="@mipmap/down_arrow"
                                    android:layout_gravity="center"
                                    android:layout_marginRight="5dp"/>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:weightSum="3"
                                android:background="@drawable/edittext_bg"
                                android:layout_margin="5dp"
                                android:id="@+id/examNameSelect"
                                android:orientation="horizontal">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="45dp"
                                        android:layout_weight="2.5"
                                        android:layout_gravity="center"
                                        android:padding="10dp"
                                        android:fontFamily="@font/rubik_regular"
                                        android:textSize="15sp"
                                        android:layout_centerVertical="true"
                                        android:gravity="center"
                                        android:id="@+id/selectExam"
                                        android:text="Exam"
                                        android:textColor="@color/appThemeColor"/>

                                <ImageView
                                    android:layout_width="0dp"
                                    android:layout_height="20dp"
                                    android:layout_weight="0.5"
                                    android:src="@mipmap/down_arrow"
                                    android:layout_gravity="center"
                                    android:layout_marginRight="5dp"/>

                            </LinearLayout>

                        </LinearLayout>
                        <EditText
                            android:layout_width="match_parent"
                            android:layout_height="45dp"
                            android:layout_marginHorizontal="10dp"
                            android:inputType="textPassword"
                            android:id="@+id/rollNo"
                            android:textAlignment="center"
                            android:layout_marginTop="10dp"
                            android:layout_below="@+id/studentClassSecLayout"
                            android:textColorHint="@color/appThemeOpacity"
                            android:textColor="@color/appThemeColor"
                            android:background="@drawable/edittext_bg"
                            android:hint="Roll Number" />

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:text="Search"
                            android:background="@drawable/login_btn"
                            android:textColor="@color/white"
                            android:fontFamily="@font/rubik_bold"
                            android:paddingHorizontal="20dp"
                            android:layout_below="@+id/rollNo"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="20dp"
                            android:layout_centerHorizontal="true" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/studentList"
                android:layout_margin="5dp"
                android:layout_below="@id/searchLayout" />

        </RelativeLayout>
    </ScrollView>

</RelativeLayout>