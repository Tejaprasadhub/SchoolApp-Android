<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@mipmap/login_bg"
    android:layout_gravity="center"
    tools:context=".ui.Activities.ChangePasswordActivity">
<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/contentStart"
        android:textColor="@color/black"
        android:id="@+id/content1"
        android:fontFamily="@font/rubik_regular"
        android:text="we have sent an OTP to your EmailId :"
        android:textAlignment="center"
        />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:id="@+id/content2"
        android:layout_marginTop="10dp"
        android:layout_below="@id/content1"
        android:textSize="14sp"
        android:fontFamily="@font/rubik_bold"
        android:text="Usharani19996@gmail.com"
        android:textAlignment="center"
        />

    <com.mukesh.OtpView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:itemBackground="@color/white"
        app:OtpViewType="rectangle"
        app:OtpItemCount="4"
        android:fontFamily="@font/rubik_bold"
        android:layout_below="@+id/content2"
        android:textSize="18sp"
        android:id="@+id/otp"
        android:textColor="@color/appThemeColor"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_centerHorizontal="true"
        app:OtpLineColor="@color/appThemeColor"
        app:OtpItemSpacing="10dp"
        android:layout_marginTop="15dp"
        />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:id="@+id/resend_layout"
        android:layout_below="@+id/otp"
        android:gravity="center"
        android:layout_marginTop="15dp"
        >
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Didn't receive OTP?"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:textAlignment="textEnd"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Resend"
            android:textSize="15sp"
            android:textColor="@color/appThemeColor"
            android:textAlignment="textEnd"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Password"
        android:fontFamily="@font/rubik_bold"
        android:id="@+id/setpass_heading"
        android:layout_below="@id/resend_layout"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:textColor="@color/black"
        android:textSize="18sp"/>

    <EditText
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@+id/setpass_heading"
        android:layout_marginHorizontal="20dp"
        android:inputType="textPassword"
        android:id="@+id/newPass"
        android:textAlignment="center"
        android:layout_marginTop="25dp"
        android:textColorHint="@color/appThemeOpacity"
        android:textColor="@color/appThemeColor"
        android:background="@drawable/edittext_bg"
        android:hint="New Password" />

    <EditText
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@+id/newPass"
        android:layout_marginHorizontal="20dp"
        android:inputType="textPassword"
        android:id="@+id/confirmPass"
        android:textAlignment="center"
        android:layout_marginTop="25dp"
        android:textColorHint="@color/appThemeOpacity"
        android:textColor="@color/appThemeColor"
        android:background="@drawable/edittext_bg"
        android:hint="Confirm Password" />

    <Button
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:id="@+id/setpassword"
        android:layout_below="@+id/confirmPass"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/login_btn"
        android:layout_marginTop="25dp"
        android:textStyle="bold"
        android:layout_marginBottom="50dp"
        android:text="Confirm"
        android:textColor="@color/white"
        android:textAllCaps="false"
        />
