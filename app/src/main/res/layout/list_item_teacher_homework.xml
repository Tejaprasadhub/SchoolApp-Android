<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="5dp">
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:weightSum="7"
                android:id="@+id/homework_title_layout"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="10dp"
                    android:src="@mipmap/book" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:layout_gravity="center"
                    android:text="Maths"
                    android:id="@+id/hm_title"
                    android:textSize="15sp"
                    android:layout_marginLeft="5dp"
                    android:textColor="@color/appThemeColor"
                    android:fontFamily="@font/rubik_bold"/>
                <ImageButton
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:src="@mipmap/download"
                    android:id="@+id/downloadBtn"
                    android:background="@android:color/transparent"
                    android:layout_gravity="right"
                    android:layout_marginRight="15dp"
                    android:layout_weight="0.5" />
                <ImageButton
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:src="@mipmap/delete"
                    android:background="@android:color/transparent"
                    android:layout_gravity="right"
                    android:id="@+id/deleteBtn"
                    android:layout_marginRight="10dp"
                    android:layout_weight="0.5" />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="5dp"
                android:id="@+id/classDetailsLayout"
                android:layout_below="@+id/homework_title_layout"
                android:weightSum="2">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    android:layout_gravity="center"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Class :"
                        android:layout_marginLeft="10dp"
                        android:textSize="14sp"
                        android:id="@+id/classHeading"
                        android:textColor="@color/black"
                        android:fontFamily="@font/rubik_bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5th"
                        android:id="@+id/className"
                        android:lines="1"
                        android:ellipsize="end"
                        android:layout_marginLeft="10dp"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:fontFamily="@font/rubik_regular"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.5"
                    android:layout_gravity="center"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Section :"
                        android:layout_marginLeft="10dp"
                        android:textSize="14sp"
                        android:id="@+id/section_heading"
                        android:textColor="@color/black"
                        android:fontFamily="@font/rubik_bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A"
                        android:id="@+id/section"
                        android:layout_marginLeft="10dp"
                        android:lines="1"
                        android:ellipsize="end"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:fontFamily="@font/rubik_regular"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_gravity="center"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Subject :"
                        android:layout_marginLeft="10dp"
                        android:textSize="14sp"
                        android:id="@+id/subject_heading"
                        android:textColor="@color/black"
                        android:fontFamily="@font/rubik_bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Telugu"
                        android:id="@+id/subject"
                        android:layout_marginLeft="10dp"
                        android:lines="1"
                        android:ellipsize="end"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:fontFamily="@font/rubik_regular"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:id="@+id/submissionDetailsLayout"
                android:layout_marginBottom="10dp"
                android:layout_below="@+id/classDetailsLayout"
                android:weightSum="2">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_gravity="center"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assign Date :"
                        android:layout_marginLeft="10dp"
                        android:textSize="14sp"
                        android:id="@+id/assignHeading"
                        android:textColor="@color/black"
                        android:fontFamily="@font/rubik_bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2020-10-23"
                        android:id="@+id/assigndate"
                        android:lines="1"
                        android:ellipsize="end"
                        android:layout_marginLeft="10dp"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:fontFamily="@font/rubik_regular"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_gravity="center"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Submission date :"
                        android:layout_marginLeft="10dp"
                        android:textSize="14sp"
                        android:id="@+id/submit_heading"
                        android:textColor="@color/black"
                        android:fontFamily="@font/rubik_bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2020-10-01"
                        android:id="@+id/submissiondate"
                        android:layout_marginLeft="10dp"
                        android:lines="1"
                        android:ellipsize="end"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:fontFamily="@font/rubik_regular"/>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>